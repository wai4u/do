#include"io.hpp"
tuple<int,int,int>extgcd(int a,int b){
	if(b==0)return{a,1,0};
	auto[g,x,y]=extgcd(b,a%b);
	return{g,y,x-a/b*y};
}
int main(){
	int t;
	cin>>t;
	while(t--){
		int n;
		cin>>n;
		vector<long>a(n),b(n);
		for(int i=0;i<n;i++)cin>>a[i];
		for(int i=0;i<n;i++)cin>>b[i];
		bool ok=0;
		vector<int>x(n);
		for(int i=0;i<n;i++){
			if(a[i]>0&&b[i]<0){
				x[i]=1;
				ok=1;
				break;
			}
			if(a[i]<0&&b[i]>0){
				x[i]=-1;
				ok=1;
				break;
			}
		}
		if(ok){
			cout<<"Yes"<<'\n';
			for(int i=0;i<n;i++)cout<<x[i]<<' ';
			cout<<'\n';
			continue;
		}
		vector<bool>rev(n);
		vector<pair<int,int>>cand(n);
		for(int i=0;i<n;i++){
			if(a[i]<0||b[i]<0){
				rev[i]=1;
				a[i]=abs(a[i]);
				b[i]=abs(b[i]);
			}
			//if(a[i]==0&&b[i]==0)continue;
			cand[i]=make_pair(a[i]-b[i],i);
		}
		sort(cand.begin(),cand.end());
		int i=cand.back().second;
		int j=cand[0].second;
		if(a[i]-b[i]==a[j]-b[j]){
			cout<<"No"<<'\n';
			continue;
		}
		cout<<"Yes"<<'\n';
		auto[g,s,t]=extgcd(a[i],a[j]);
		long l=lcm<long>(a[i],a[j]);
		s+=l/a[i];
		t-=l/a[j];
		a[i]*=s,b[i]*=s;
		a[j]*=t,b[j]*=t;
		assert(a[i]+a[j]>0&&b[i]+b[j]<0);
		//cout<<a[i]+a[j]<<' '<<b[i]+b[j]<<'\n';
		x[i]=s;
		x[j]=t;
		/*
		int k=a[j]/a[i]+1;
		//flush();
		assert(a[i]*k-a[j]>0);
		x[i]=k;
		a[i]*=k;
		b[i]*=k;
		k=b[i]/b[j]+1;
		assert(b[i]-b[j]*k<0&&a[i]-a[j]*k>0);
		x[j]=-k;
		*/
		if(rev[i])x[i]=-x[i];
		if(rev[j])x[j]=-x[j];
		cout<<x<<'\n';
	}
}
