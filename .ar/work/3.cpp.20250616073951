#include<bits/stdc++.h>
using namespace std;
long ten(int k){return k?ten(k-1)*10:1;}
// 高速な modular multiplication (オーバーフロー対策)
uint64_t mulmod(uint64_t a, uint64_t b, uint64_t mod) {
    if (mod <= (1ULL << 31)) {
        return (a * b) % mod;
    }
    // 128bit演算を使用
    return (((__uint128_t)a * b) % mod);
}

// 高速な modular exponentiation
uint64_t powmod(uint64_t base, uint64_t exp, uint64_t mod) {
    uint64_t result = 1;
    base %= mod;
    while (exp > 0) {
        if (exp & 1) {
            result = mulmod(result, base, mod);
        }
        base = mulmod(base, base, mod);
        exp >>= 1;
    }
    return result;
}

// Miller-Rabin素数判定
bool miller_rabin(uint64_t n, int k = 10) {
    if (n < 2) return false;
    if (n == 2 || n == 3) return true;
    if (n % 2 == 0) return false;

    // n-1 = d * 2^r の形に分解
    uint64_t d = n - 1;
    int r = 0;
    while (d % 2 == 0) {
        d /= 2;
        r++;
    }

    // 乱数生成器
    random_device rd;
    mt19937_64 gen(rd());
    uniform_int_distribution<uint64_t> dis(2, n - 2);

    // k回テスト
    for (int i = 0; i < k; i++) {
        uint64_t a = dis(gen);
        uint64_t x = powmod(a, d, n);

        if (x == 1 || x == n - 1) continue;

        bool composite = true;
        for (int j = 0; j < r - 1; j++) {
            x = mulmod(x, x, n);
            if (x == n - 1) {
                composite = false;
                break;
            }
        }

        if (composite) return false;
    }

    return true;
}

// 範囲[l, r)から乱択で素数を1つ見つける
uint64_t find_random_prime(uint64_t l, uint64_t r) {
    assert(l < r);

    random_device rd;
    mt19937_64 gen(rd());
    uniform_int_distribution<uint64_t> dis(l, r - 1);

    // 最大試行回数を設定（無限ループ防止）
    const int max_attempts = 1000000;

    for (int attempt = 0; attempt < max_attempts; attempt++) {
        uint64_t candidate = dis(gen);

        // 偶数なら奇数に調整（2は別途チェック）
        if (candidate > 2 && candidate % 2 == 0) {
            candidate++;
            if (candidate >= r) continue;
        }

        if (miller_rabin(candidate)) {
            return candidate;
        }
    }

    // 乱択で見つからない場合は線形探索
    //cout << "乱択で見つからないため線形探索に切り替えます..." << endl;

    for (uint64_t i = l; i < r; i++) {
        if (miller_rabin(i)) {
            return i;
        }
    }

    return 0; // 素数が見つからない
}
