#include<bits/stdc++.h>
using namespace std;
int main(){
	int n;
	cin>>n;
	long ans=0;
	vector<int>x(n);
	for(int i=0;i<n;i++)cin>>x[i];
	vector<vector<pair<int,int>>>g(n);
	for(int i=0;i<n-1;i++){
		int u,v,w;
		cin>>u>>v>>w;
		u--,v--;
		g[u].push_back(make_pair(v,w));
		g[v].push_back(make_pair(u,w));
	}
	vector<long>s(n),val(n);
	auto dfs=[&](auto dfs,int u,int p)->void{
		for(auto[v,w]:g[u])if(v!=p){
			dfs(dfs,v,u);
			s[u]+=(long)abs(x[v])*w;
			x[u]+=x[v];
		}
	};
	dfs(dfs,0,-1);
	for(int i=0;i<n;i++)ans+=s[i];
	assert(x[0]==0);
	cout<<ans<<'\n';
}
