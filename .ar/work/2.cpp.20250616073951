tuple<int,int,int>extgcd(int a,int b){
	if(b==0){
		if(a<0)return {-a,-1,0};
		else return {a,1,0};
	}
	auto[g,x,y]=extgcd(b,a%b);
	return{g,y,x-a/b*y};
}
