#include<bits/stdc++.h>
using namespace std;
#include<atcoder/dsu>
int main(){
	int n,q;
	cin>>n>>q;
	//boruvkaか
	vector<int>x(n),y(n);
	for(int i=0;i<n;i++)cin>>x[i]>>y[i];
	vector<tuple<int,int,int>>qs(q);
	int N=n;
	for(int i=0;i<q;i++){
		int op;
		cin>>op;
		if(op==1){
			int a,b;
			cin>>a>>b;
			int j=x.size();
			x.push_back(a);
			y.push_back(b);
			qs.push_back(make_tuple(op,j,-1));
			N++;
		}
		if(op==2){
			qs.push_back(make_tuple(2,-1,-1));
		}
		if(op==3){
			int u,v;
			cin>>u>>v;
			u--,v--;
			qs.push_back(make_tuple(3,u,v));
		}
	}
	//for(int i=0;i<n;i++)
	//vector<bool>enabled(N);
	//for(int i=0;i<n;i++)enabled[i]=1;
	using T=tuple<long,int,int>;
	priority_queue<T,vector<T>,greater<T>>que;
	//n=N;
	atcoder::dsu uf(N);
	vector<vector<T>>todo(N);
	for(int i=0;i<N;i++)for(int j=0;j<i;j++){
		long d=abs(x[i]-x[j])+abs(y[i]-y[j]);
		todo[i].push_back(make_tuple(d,i,j));
		if(i<n)que.push(make_tuple(d,i,j));
	}
	for(auto[op,u,v]:qs){
		if(op==1){
			//enabled[u]=1;
			//continue;
			for(auto e:todo[u])que.push(e);
			n++;
		}
		if(op==3){
			cout<<(uf.same(u,v)?"Yes":"No")<<'\n';
		}
		if(op==2){
			while(que.size()){
				auto[d,u,v]=que.top();
				if(uf.same(u,v)){
					que.pop();
					continue;
				}
				break;
			}
			if(que.empty()){
				assert(uf.size(0)==n);
				cout<<-1<<'\n';
				continue;
			}
			long d0=get<0>(que.top());
			cout<<d0<<'\n';
			while(que.size()){
				auto[d,u,v]=que.top();
				if(d>d0)break;
				que.pop();
				uf.merge(u,v);
			}
		}
	}
}
