#include"io.hpp"
//https://onlinejudge.u-aizu.ac.jp/courses/library/5/GRL/6/GRL_6_B
//successive shortest path
//bellman fordによる初期ポテンシャル。
//最初にnegative edgeがあっても良いが、cycleはだめ。
int main(){
	int n,m,in;
	cin>>n>>m>>in;
	struct edge{
		int to,rev,c,w;
	};
	vector<vector<edge>>g(n);
	for(int i=0;i<m;i++){
		int u,v,c,w;
		cin>>u>>v>>c>>w;
		g[u].push_back({v,(int)g[v].size(),c,w});
		g[v].push_back({u,(int)g[u].size()-1,0,-w});
	}
	int inf=1e9;
	vector<long>h(n,inf);
	h[0]=0;
	bool upd=1;
	while(upd){
		upd=0;
		for(int u=0;u<n;u++)if(h[u]<inf){
			for(auto&e:g[u])if(e.c&&h[u]+e.w<h[e.to]){
				h[e.to]=h[u]+e.w;
				upd=1;
			}
		}
	}
	assert(h[0]==0);
	using T=pair<int,int>;
	priority_queue<T,vector<T>,greater<T>>que;
	vector<int>d;
	vector<pair<int,int>>p(n);
	int res=0;
	while(in){
		d.assign(n,inf);
		d[0]=0;
		que.push(make_pair(0,0));
		while(que.size()){
			auto[du,u]=que.top();que.pop();
			if(du>d[u])continue;
			int i=-1;
			for(auto&e:g[u]){
				i++;
				if(!e.c)continue;
				int v=e.to;
				int dv=du+e.w+h[u]-h[v];
				assert(dv>=0);
				if(dv<d[v]){
					d[v]=dv;
					que.push(make_pair(dv,v));
					p[v]=make_pair(u,i);
				}
			}
		}
		if(d[n-1]==inf)break;
		int u=n-1;
		int f=in;
		while(u!=0){
			auto[v,i]=p[u];
			f=min(f,g[v][i].c);
			u=v;
		}
		u=n-1;
		while(u!=0){
			auto[v,i]=p[u];
			auto&e=g[v][i];
			e.c-=f;
			g[u][e.rev].c+=f;
			u=v;
		}
		in-=f;
		res+=f*(d[n-1]+h[n-1]);
	}
	cout<<(in?-1:res)<<'\n';
}
