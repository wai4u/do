#include"io.hpp"
//https://onlinejudge.u-aizu.ac.jp/courses/library/5/GRL/6/GRL_6_B
//successive shortest path
//https://hos.ac/slides/20150319_flow.pdf
//https://snuke.hatenablog.com/entry/2017/06/07/115821
//https://pione.hatenablog.com/entry/2021/02/28/062450
//https://pione.hatenablog.com/entry/2021/02/28/075034
//https://github.com/kotatsugame/library/blob/master/graph/MCF.cpp
//O(FMlogM) basic
//O(NM+FMlogM) allow negative
//negative cycle not allowed.
template<class T,class W>
struct MCF{
	struct edge{int to,rev;T c;W w;};
	int n;
	vector<vector<edge>>g;
	bool neg;
	vector<T>h,d;
	vector<pair<int,int>>p;
	W inf=numeric_limits<W>::max();
	MCF(int n,bool neg=0):n(n),g(n),neg(neg){}
	void add_edge(int u,int v,T c,W w){
		assert(c>=0);
		if(!neg)assert(w>=0);
		g[u].push_back({v,(int)g[v].size(),c,w});
		g[v].push_back({u,(int)g[u].size()-1,0,-w});
	}
	void init_potential(){
		for(int t=1;t<=n;t++){
			bool upd=0;
			for(int u=0;u<n;u++)if(h[u]<inf){
				for(auto&e:g[u])if(e.c&&h[u]+e.w<h[e.to]){
					h[e.to]=h[u]+e.w;
					upd=1;
				}
			}
			if(!upd)break;
			assert(t<n);
		}
	}
	pair<T,W>flow(int s,int t,T in=numeric_limits<T>::max()){
		if(neg){
			h.assign(n,inf),h[s]=0;
			init_potential();
		}else h.assign(n,0);
		T out=0;
		W cost=0;
		p.resize(n);
		using P=pair<W,int>;
		priority_queue<P,vector<P>,greater<P>>que;
		while(in>0){
			d.assign(n,inf),d[s]=0;
			que.push(make_pair(0,s));
			while(que.size()){
				auto[du,u]=que.top();que.pop();
				if(du>d[u])continue;
				int i=-1;
				for(auto&e:g[u]){
					i++;
					if(!e.c)continue;
					int v=e.to;
					int dv=du+e.w+h[u]-h[v];
					if(dv<d[v]){
						d[v]=dv;
						que.push(make_pair(dv,v));
						p[v]=make_pair(u,i);
					}
				}
			}
			if(d[t]==inf)break;
			//for(int i=0;i<n;i++)if(d[i]<inf)h[i]+=d[i];
			for(int i=0;i<n;i++)h[i]+=d[i];//infになったら二度と使わないからoverflowしても良い
			T f=in;
			int u=t;
			while(u!=s){
				auto[v,i]=p[u];
				f=min(f,g[v][i].c);
				u=v;
			}
			u=t;
			while(u!=s){
				auto[v,i]=p[u];
				auto&e=g[v][i];
				e.c-=f;
				g[u][e.rev].c+=f;
				u=v;
			}
			in-=f;
			out+=f;
			cost+=f*h[t];
		}
		return{out,cost};
	}
};
int main(){
	int n,m,in;
	cin>>n>>m>>in;
	MCF<int,int>g(n);
	for(int i=0;i<m;i++){
		int u,v,c,w;
		cin>>u>>v>>c>>w;
		g.add_edge(u,v,c,w);
	}
	auto[f,c]=g.flow(0,n-1,in);
	cout<<(f==in?c:-1)<<'\n';
}
