#include<bits/stdc++.h>
using namespace std;
int main(){
	int n,l;
	cin>>n>>l;
	vector<int>d(n-1);
	for(int i=0;i<n-1;i++)cin>>d[i];
	if(l%3){cout<<0<<'\n';return 0;}
	int x=0;
	l/=3;
	auto c=vector(3,vector(l,0l));
	c[0][0]=1;
	for(int i=0;i<n-1;i++){
		x+=d[i];
		x%=l*3;
		c[x/l][x%l]++;
	}
	long ans=0;
	for(int r=0;r<l;r++){
		ans+=c[0][r]*c[1][r]*c[2][r];
	}
	cout<<ans<<'\n';
}
